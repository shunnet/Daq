<UserControl
    x:Class="Snet.Iot.Daq.view.PluginSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Snet.Iot.Daq.view"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Snet.Iot.Daq.viewModel"
    xmlns:snet="https://shunnet.top"
    xmlns:ui="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:uis="http://schemas.lepo.co/wpfui/2022/xaml"
    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
    snet:ResxLocalizationProvider.DefaultDictionary="Language">
    <UserControl.DataContext>
        <model:PluginSettingsModel />
    </UserControl.DataContext>
    <GroupBox
        Margin="5"
        Padding="0"
        ui:ElevationAssist.Elevation="Dp2"
        ui:GroupBoxAssist.HeaderPadding="7"
        Header="{Binding}"
        Style="{StaticResource MaterialDesignCardGroupBox}">
        <GroupBox.HeaderTemplate>
            <DataTemplate>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:PackIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Kind="Tools" />
                    <TextBlock
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{snet:Loc 插件设置}"
                        TextAlignment="Center" />
                </StackPanel>
            </DataTemplate>
        </GroupBox.HeaderTemplate>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="570" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!--  插件列表  -->
            <Grid Grid.Column="0">
                <GroupBox
                    Grid.Row="0"
                    Margin="5"
                    Padding="0"
                    ui:ElevationAssist.Elevation="Dp2"
                    ui:GroupBoxAssist.HeaderPadding="7"
                    Header="{Binding}"
                    Style="{StaticResource MaterialDesignCardGroupBox}">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <ui:PackIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="ListBox" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 插件列表}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <!--  上传或移除  -->
                        <Border
                            Grid.Row="0"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                            BorderThickness="0,0,0,1">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <snet:ComboBoxControl
                                    DisplayMemberPath="Key"
                                    Hint="{snet:Loc 插件类型}"
                                    Icon="{DynamicResource Type}"
                                    ItemsSource="{Binding ComboBoxItemsSource}"
                                    SelectedItem="{Binding ComboBoxSelectedItem}" />

                                <snet:ButtonControl
                                    Grid.Column="1"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    BorderThickness="0,0,0,0"
                                    Command="{Binding UploadPlugin}"
                                    Content="{snet:Loc 上传插件}"
                                    Icon="{DynamicResource Uploading}" />
                            </Grid>
                        </Border>
                        <!--  插件列表  -->
                        <DataGrid
                            Grid.Row="1"
                            Margin="5"
                            AutoGenerateColumns="False"
                            Background="Transparent"
                            BorderThickness="0"
                            ColumnHeaderHeight="45"
                            GridLinesVisibility="None"
                            IsReadOnly="True"
                            ItemsSource="{Binding PluginList}"
                            SelectedItem="{Binding PluginListSelectedItem}"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                            <i:Interaction.Triggers>
                                <!--  内容菜单打开  -->
                                <i:EventTrigger EventName="ContextMenuOpening">
                                    <snet:EventCommand Command="{Binding DataGrid_ContextMenuOpening}" />
                                </i:EventTrigger>
                                <!--  右键按下  -->
                                <i:EventTrigger EventName="PreviewMouseRightButtonDown">
                                    <snet:EventCommand Command="{Binding DataGrid_PreviewMouseRightButtonDown}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <DataGrid.Resources>

                                <!--  滚动条样式  -->
                                <Style BasedOn="{StaticResource UiScrollBar}" TargetType="ScrollBar" />

                                <!--  Header样式  -->
                                <Style
                                    x:Key="DataGridColumnHeaderStyle"
                                    BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}"
                                    TargetType="{x:Type DataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>

                                <!--  单元格内容居中样式  -->
                                <Style
                                    x:Key="DataGridCellStyle"
                                    BasedOn="{StaticResource DefaultDataGridCellStyle}"
                                    TargetType="{x:Type DataGridCell}">
                                    <Setter Property="Height" Value="45" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>

                            </DataGrid.Resources>
                            <!--  右键菜单  -->
                            <DataGrid.ContextMenu>
                                <ContextMenu VerticalContentAlignment="Center">
                                    <ContextMenu.Style>
                                        <Style BasedOn="{StaticResource UiContextMenu}" TargetType="{x:Type ContextMenu}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=PlacementTarget.SelectedItem, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContextMenu.Style>
                                    <uis:MenuItem
                                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                        Command="{Binding AddPluginConfig}"
                                        Header="{snet:Loc 添加插件配置}"
                                        Icon="{uis:SymbolIcon Symbol=Add24,
                                                              Filled=False}" />
                                    <Separator Margin="0,-4,0,-3" Padding="0" />
                                    <uis:MenuItem
                                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                        Command="{Binding RemovePlugin}"
                                        Header="{snet:Loc 移除插件}"
                                        Icon="{uis:SymbolIcon Symbol=TrayItemRemove20,
                                                              Filled=False}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>

                                <DataGridTextColumn
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Type}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Type}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 类型}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Version}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Version}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 版本}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>


                                <DataGridTextColumn
                                    Width="*"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Name}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Name}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 名称}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>





                                <DataGridTextColumn
                                    Width="170"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Time, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Time}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 添加时间}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
            </Grid>
            <!--  插件配置  -->
            <GroupBox
                Grid.Column="1"
                Margin="0,5,5,5"
                Padding="0"
                ui:ElevationAssist.Elevation="Dp2"
                ui:GroupBoxAssist.HeaderPadding="7"
                Header="{Binding}"
                Style="{StaticResource MaterialDesignCardGroupBox}">
                <GroupBox.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Image
                                Width="15"
                                Height="15"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Source="{DynamicResource Config}"
                                Stretch="Fill" />
                            <TextBlock
                                Margin="5,0,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{snet:Loc 插件配置}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </GroupBox.HeaderTemplate>
                <Grid>
                    <Button
                        Grid.Column="1"
                        Margin="0,-32,0,0"
                        Padding="10,0,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        ui:ButtonAssist.CornerRadius="0,4,0,0"
                        Command="{Binding StatusVerification}"
                        Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                        ToolTip="打开成功说明验证通过，状态正常">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Image
                                    Width="15"
                                    Height="15"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{DynamicResource Verification}"
                                    Stretch="Fill" />
                            </Grid>
                            <Grid Grid.Column="2">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 状态验证}"
                                    TextAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Button>
                    <!--  插件列表  -->
                    <DataGrid
                        Margin="5"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        ColumnHeaderHeight="45"
                        GridLinesVisibility="None"
                        IsReadOnly="True"
                        ItemsSource="{Binding PluginConfig}"
                        SelectedItem="{Binding PluginConfigSelectedItem}"
                        SelectionMode="Single"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                        <i:Interaction.Triggers>
                            <!--  内容菜单打开  -->
                            <i:EventTrigger EventName="ContextMenuOpening">
                                <snet:EventCommand Command="{Binding DataGrid_ContextMenuOpening}" />
                            </i:EventTrigger>
                            <!--  右键按下  -->
                            <i:EventTrigger EventName="PreviewMouseRightButtonDown">
                                <snet:EventCommand Command="{Binding DataGrid_PreviewMouseRightButtonDown}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <DataGrid.Resources>

                            <!--  滚动条样式  -->
                            <Style BasedOn="{StaticResource UiScrollBar}" TargetType="ScrollBar" />

                            <!--  Header样式  -->
                            <Style
                                x:Key="DataGridColumnHeaderStyle"
                                BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}"
                                TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>

                            <!--  单元格内容居中样式  -->
                            <Style
                                x:Key="DataGridCellStyle"
                                BasedOn="{StaticResource DefaultDataGridCellStyle}"
                                TargetType="{x:Type DataGridCell}">
                                <Setter Property="Height" Value="45" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>

                        </DataGrid.Resources>
                        <!--  右键菜单  -->
                        <DataGrid.ContextMenu>
                            <ContextMenu VerticalContentAlignment="Center">
                                <ContextMenu.Style>
                                    <Style BasedOn="{StaticResource UiContextMenu}" TargetType="{x:Type ContextMenu}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=PlacementTarget.SelectedItem, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContextMenu.Style>
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding UpdatePluginConfig}"
                                    Header="{snet:Loc 修改插件配置}"
                                    Icon="{uis:SymbolIcon Symbol=CubeRotate20,
                                                          Filled=False}" />
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding CopySN}"
                                    Header="{snet:Loc 复制唯一标识符}"
                                    Icon="{uis:SymbolIcon Symbol=Copy24,
                                                          Filled=False}" />
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding Produce}"
                                    Header="{snet:Loc 生产}"
                                    Icon="{uis:SymbolIcon Symbol=CalendarToday20,
                                                          Filled=False}">
                                    <uis:MenuItem.Style>
                                        <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Mq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </uis:MenuItem.Style>
                                </uis:MenuItem>
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding Read}"
                                    Header="{snet:Loc 读取}"
                                    Icon="{uis:SymbolIcon Symbol=ArrowExit20,
                                                          Filled=False}">
                                    <uis:MenuItem.Style>
                                        <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Daq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </uis:MenuItem.Style>
                                </uis:MenuItem>
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding Write}"
                                    Header="{snet:Loc 写入}"
                                    Icon="{uis:SymbolIcon Symbol=ArrowEnter20,
                                                          Filled=False}">
                                    <uis:MenuItem.Style>
                                        <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Daq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </uis:MenuItem.Style>
                                </uis:MenuItem>
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding SettingsWebApi}"
                                    Header="{snet:Loc 设置WebApi}"
                                    Icon="{uis:SymbolIcon Symbol=Settings20,
                                                          Filled=False}">
                                    <uis:MenuItem.Style>
                                        <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Daq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </uis:MenuItem.Style>
                                </uis:MenuItem>
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding UpdateWebApi}"
                                    Header="{snet:Loc 修改WebApi}"
                                    Icon="{uis:SymbolIcon Symbol=MoreVertical16,
                                                          Filled=False}">
                                    <uis:MenuItem.Style>
                                        <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Daq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </uis:MenuItem.Style>
                                </uis:MenuItem>
                                <Separator>
                                    <Separator.Style>
                                        <Style BasedOn="{StaticResource MaterialDesignSeparator}" TargetType="Separator">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Setter Property="Margin" Value="0,-4,0,-3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Daq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Separator.Style>
                                </Separator>

                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding RemoveWebApi}"
                                    Header="{snet:Loc 移除WebApi}"
                                    Icon="{uis:SymbolIcon Symbol=DeleteDismiss20,
                                                          Filled=False}">
                                    <uis:MenuItem.Style>
                                        <Style BasedOn="{StaticResource UiMenuItem}" TargetType="uis:MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.PluginConfigSelectedItem.Type, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Daq">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </uis:MenuItem.Style>
                                </uis:MenuItem>

                                <Separator Margin="0,-4,0,-3" Padding="0" />
                                <uis:MenuItem
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Command="{Binding RemovePluginConfig}"
                                    Header="{snet:Loc 移除插件配置}"
                                    Icon="{uis:SymbolIcon Symbol=Delete48,
                                                          Filled=False}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                Binding="{Binding Index}"
                                CellStyle="{StaticResource DataGridCellStyle}"
                                HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                <DataGridTextColumn.Header>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="13"
                                            Height="13"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{DynamicResource Index}"
                                            Stretch="Fill" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{snet:Loc 序号}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>


                            <DataGridTemplateColumn
                                snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                CellStyle="{StaticResource DataGridCellStyle}"
                                HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="13"
                                            Height="13"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{DynamicResource Status}"
                                            Stretch="Fill" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{snet:Loc 状态}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>

                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <snet:LedGaugeControl
                                            Width="17"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsOn="{Binding Status}"
                                            OffLightness="0.1"
                                            ToolTip="{Binding StatusMessage}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>




                            <DataGridTextColumn
                                snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                Binding="{Binding Type}"
                                CellStyle="{StaticResource DataGridCellStyle}"
                                HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                <DataGridTextColumn.Header>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="13"
                                            Height="13"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{DynamicResource Type}"
                                            Stretch="Fill" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{snet:Loc 类型}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>



                            <DataGridTextColumn
                                snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                Binding="{Binding Name}"
                                CellStyle="{StaticResource DataGridCellStyle}"
                                HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                <DataGridTextColumn.Header>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="13"
                                            Height="13"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{DynamicResource Name}"
                                            Stretch="Fill" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{snet:Loc 名称}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>


                            <DataGridTextColumn
                                Width="*"
                                snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                Binding="{Binding SN}"
                                CellStyle="{StaticResource DataGridCellStyle}"
                                HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                <DataGridTextColumn.Header>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="13"
                                            Height="13"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{DynamicResource SN}"
                                            Stretch="Fill" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{snet:Loc 唯一标识符}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>

                            <DataGridTextColumn
                                Width="170"
                                snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq"
                                snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                Binding="{Binding Time, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                CellStyle="{StaticResource DataGridCellStyle}"
                                HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                <DataGridTextColumn.Header>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="13"
                                            Height="13"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Source="{DynamicResource Time}"
                                            Stretch="Fill" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{snet:Loc 最后更新时间}"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>


    </GroupBox>
</UserControl>