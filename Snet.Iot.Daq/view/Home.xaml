<UserControl
    x:Class="Snet.Iot.Daq.view.Home"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Snet.Iot.Daq.view"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:snet="https://shunnet.top"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
    snet:ResxLocalizationProvider.DefaultDictionary="Language"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid
            Grid.Row="0"
            Height="200"
            Margin="40,40,40,0"
            Background="Transparent">
            <Border
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="8">
                <Border.Effect>
                    <BlurEffect Radius="5" />
                </Border.Effect>
                <Border.Background>
                    <ImageBrush
                        ImageSource="pack://application:,,,/Snet.Iot.Daq;component/resources/image/home-head.png"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Border
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="8">
                <Grid>
                    <StackPanel
                        Margin="48,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Transparent">
                        <TextBlock
                            Margin="0,0,0,10"
                            FontFamily="宋体"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Font.Head.Foreground}"
                            Text="{snet:Loc 物联网插件化数据采集}" />
                        <TextBlock
                            Margin="0,5,0,5"
                            FontFamily="宋体"
                            Foreground="{DynamicResource Font.Content.Foreground}"
                            Text="{snet:Loc 快速搭建数据采集服务终端}" />
                        <TextBlock
                            FontFamily="宋体"
                            Foreground="{DynamicResource Font.Content.Foreground}"
                            Text="{snet:Loc 使用 .net10 WPF 终端形式开发全流程配置采集与消息队列转发}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="1" Margin="40,20,40,40">
            <Grid.Background>
                <ImageBrush
                    ImageSource="pack://application:,,,/Snet.Iot.Daq;component/resources/image/home-background.png"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Stretch="Uniform" />
            </Grid.Background>
            <Canvas x:Name="MainCanvas" Panel.ZIndex="2" />
        </Grid>
    </Grid>
</UserControl>
