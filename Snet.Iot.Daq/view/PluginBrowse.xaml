<UserControl
    x:Class="Snet.Iot.Daq.view.PluginBrowse"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Snet.Iot.Daq.handler"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Snet.Iot.Daq.view"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Snet.Iot.Daq.viewModel"
    xmlns:snet="https://shunnet.top"
    xmlns:ui="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:uis="http://schemas.lepo.co/wpfui/2022/xaml"
    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
    snet:ResxLocalizationProvider.DefaultDictionary="Language">
    <UserControl.DataContext>
        <model:PluginBrowseModel />
    </UserControl.DataContext>
    <GroupBox
        Margin="5"
        Padding="0"
        ui:ElevationAssist.Elevation="Dp2"
        ui:GroupBoxAssist.HeaderPadding="7"
        Header="{Binding}"
        Style="{StaticResource MaterialDesignCardGroupBox}">
        <GroupBox.HeaderTemplate>
            <DataTemplate>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:PackIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Kind="OpenInBrowser" />
                    <TextBlock
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{snet:Loc 插件浏览}"
                        TextAlignment="Center" />
                </StackPanel>
            </DataTemplate>
        </GroupBox.HeaderTemplate>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!--  搜索  -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <uis:TextBox
                    Margin="5,5,0,5"
                    ClearButtonEnabled="True"
                    Icon="{uis:SymbolIcon Symbol=CalligraphyPen24}"
                    PlaceholderText="{snet:Loc 查询}"
                    Text="{Binding QueryCntent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <uis:TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding Query}" />
                    </uis:TextBox.InputBindings>
                </uis:TextBox>
                <Menu Grid.Column="1" HorizontalAlignment="Right">
                    <uis:MenuItem
                        Command="{Binding Query}"
                        Header="{x:Null}"
                        Icon="{uis:SymbolIcon Symbol=Search24,
                                              Filled=False}"
                        ToolTip="{snet:Loc 查询}" />

                    <Separator Width="1" Style="{StaticResource DefaultDragIndicatorStyleStyle}" />

                    <uis:MenuItem
                        Command="{Binding SelectPluginPath}"
                        Foreground="#4CAF50"
                        Header="{x:Null}"
                        Icon="{uis:SymbolIcon Symbol=Folder28,
                                              Filled=False}"
                        ToolTip="{snet:Loc 选则插件存储路径}" />
                    <uis:MenuItem
                        Command="{Binding OpenPluginPath}"
                        Foreground="#2196F3"
                        Header="{x:Null}"
                        Icon="{uis:SymbolIcon Symbol=FolderArrowLeft28}"
                        ToolTip="{snet:Loc 打开插件存储路径}" />
                    <uis:MenuItem
                        Command="{Binding ClearPluginPath}"
                        Foreground="#FD7946"
                        Header="{x:Null}"
                        Icon="{uis:SymbolIcon Symbol=SubtractCircleArrowBack20}"
                        ToolTip="{snet:Loc 清空插件存储路径}" />

                    <Separator Width="1" Style="{StaticResource DefaultDragIndicatorStyleStyle}" />

                    <uis:MenuItem
                        Command="{Binding DownloadPlugin}"
                        Foreground="#FFDD96"
                        Header="{x:Null}"
                        Icon="{uis:SymbolIcon Symbol=ArrowAutofitDown24}"
                        ToolTip="{snet:Loc 下载选中的插件}" />
                    <uis:MenuItem
                        Command="{Binding StopDownloadPlugin}"
                        Foreground="#EE1567"
                        Header="{x:Null}"
                        Icon="{uis:SymbolIcon Symbol=RecordStop48}"
                        ToolTip="{snet:Loc 停止下载插件}" />
                </Menu>
            </Grid>
            <!--  列表  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="500" />
                </Grid.ColumnDefinitions>
                <GroupBox
                    Margin="5,0,5,5"
                    Padding="0"
                    ui:ElevationAssist.Elevation="Dp2"
                    ui:GroupBoxAssist.HeaderPadding="7"
                    Header="{Binding}"
                    Style="{StaticResource MaterialDesignCardGroupBox}">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <ui:PackIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="ListStatus" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 插件列表}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <DataGrid
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="5"
                            AutoGenerateColumns="False"
                            Background="Transparent"
                            BorderThickness="0"
                            ColumnHeaderHeight="45"
                            EnableColumnVirtualization="True"
                            GridLinesVisibility="None"
                            IsReadOnly="True"
                            ItemsSource="{Binding Plugins}"
                            RowHeight="40"
                            SelectedItem="{Binding PluginsSelectedItem}"
                            SelectionMode="Single"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling">
                            <i:Interaction.Triggers>
                                <!--  内容菜单打开  -->
                                <i:EventTrigger EventName="ContextMenuOpening">
                                    <snet:EventCommand Command="{Binding DataGrid_ContextMenuOpening}" />
                                </i:EventTrigger>
                                <!--  右键按下  -->
                                <i:EventTrigger EventName="PreviewMouseRightButtonDown">
                                    <snet:EventCommand Command="{Binding DataGrid_PreviewMouseRightButtonDown}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <!--  右键菜单  -->
                            <DataGrid.ContextMenu>
                                <ContextMenu VerticalContentAlignment="Center">
                                    <ContextMenu.Style>
                                        <Style BasedOn="{StaticResource UiContextMenu}" TargetType="{x:Type ContextMenu}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=PlacementTarget.DataContext.PluginsSelectedItem, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContextMenu.Style>

                                    <uis:MenuItem
                                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                        Command="{Binding Inverse}"
                                        Header="{snet:Loc 反选}"
                                        Icon="{uis:SymbolIcon Symbol=MultiselectLtr24,
                                                              Filled=False}" />
                                    <uis:MenuItem
                                        snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                        snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                        Command="{Binding AllSelect}"
                                        Header="{snet:Loc 全选}"
                                        Icon="{uis:SymbolIcon Symbol=SelectAllOn24,
                                                              Filled=False}" />

                                </ContextMenu>
                            </DataGrid.ContextMenu>

                            <DataGrid.Resources>
                                <c:ByteArrayToImageConverterHandler x:Key="ByteArrayToImageConverter" />

                                <!--  滚动条样式  -->
                                <Style BasedOn="{StaticResource UiScrollBar}" TargetType="ScrollBar" />

                                <!--  Header样式  -->
                                <Style
                                    x:Key="DataGridColumnHeaderStyle"
                                    BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}"
                                    TargetType="{x:Type DataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>

                                <!--  单元格内容居中样式  -->
                                <Style
                                    x:Key="DataGridCellStyle"
                                    BasedOn="{StaticResource DefaultDataGridCellStyle}"
                                    TargetType="{x:Type DataGridCell}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>

                            </DataGrid.Resources>
                            <DataGrid.Columns>

                                <DataGridCheckBoxColumn
                                    ui:ColorZoneAssist.Mode="PrimaryMid"
                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ElementStyle="{StaticResource MaterialDesignSecondaryCheckBox}" />


                                <DataGridTextColumn
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Index}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Index}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 序号}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn
                                    Width="100"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource 图标}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 图标}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image
                                                Width="32"
                                                Height="32"
                                                Source="{Binding Icon, Converter={StaticResource ByteArrayToImageConverter}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Width="140"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding PackName}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource PackName}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 包名}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>


                                <DataGridTextColumn
                                    Width="120"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Version}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Version}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 版本}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn
                                    Width="*"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding Describe}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Describe}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 描述}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>


                                <DataGridTextColumn
                                    Width="150"
                                    snet:ResxLocalizationProvider.DefaultAssembly="Snet.Iot.Daq.Core"
                                    snet:ResxLocalizationProvider.DefaultDictionary="Language"
                                    Binding="{Binding UpdateTime, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                    CellStyle="{StaticResource DataGridCellStyle}"
                                    HeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                                    <DataGridTextColumn.Header>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Image
                                                Width="13"
                                                Height="13"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{DynamicResource Time}"
                                                Stretch="Fill" />
                                            <TextBlock
                                                Margin="5,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="{snet:Loc 更新时间}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border
                            Grid.Row="1"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                            BorderThickness="0,1,0,0" />
                        <snet:PageBarControl
                            Grid.Row="2"
                            PageIndexChangedCommand="{Binding PageIndexChanged}"
                            PageSize="{Binding PageSize}"
                            Total="{Binding Total}"
                            PageIndex="{Binding PageIndex}" />
                    </Grid>
                </GroupBox>
                <GroupBox
                    Grid.Column="1"
                    Margin="0,0,5,5"
                    Padding="0"
                    ui:ElevationAssist.Elevation="Dp4"
                    ui:GroupBoxAssist.HeaderPadding="7"
                    Header="{Binding}"
                    Style="{StaticResource MaterialDesignCardGroupBox}">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <ui:PackIcon
                                    Grid.Column="0"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="MessageAlertOutline" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{snet:Loc 信息}"
                                    TextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <Grid>
                        <!--  清空按钮  -->
                        <Button
                            Width="80"
                            Margin="0,-32,0,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            ui:ButtonAssist.CornerRadius="0,5,0,0"
                            Command="{Binding Clear}"
                            Style="{StaticResource MaterialDesignFlatSecondaryButton}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Image
                                        Width="15"
                                        Height="15"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Source="{DynamicResource Clear}"
                                        Stretch="Fill" />
                                </Grid>
                                <Grid Grid.Column="2">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{snet:Loc 清空}"
                                        TextAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Button>

                        <!--  数据框  -->
                        <TextBox
                            Margin="5"
                            AcceptsReturn="True"
                            BorderThickness="0,0,0,0"
                            Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                            IsReadOnly="True"
                            Style="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
                            Text="{Binding Info}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Hidden">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="TextChanged">
                                    <snet:EventCommand Command="{Binding InfoTextChanged}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

    </GroupBox>
</UserControl>
